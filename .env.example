# Server-side (Express). Never expose these to the frontend.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1
PORT=3001

# Frontend (Vite reads VITE_ prefixed vars). Safe to expose.
VITE_API_URL=http://localhost:3001
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# database
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=
# Strava integration (server-side). Get credentials at
# https://www.strava.com/settings/api — set Authorization Callback Domain to localhost
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REDIRECT_URI=http://localhost:3001/api/strava/callback
